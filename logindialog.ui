                                stop:0 #66B3FF, stop:1 #A569BD); /* 悬停变色 */
      box-shadow: 0 4px 15px rgba(74, 144, 226, 0.3); /* 阴影 */
    }
    QPushButton:pressed {
      background: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
                                stop:0 #2C3E50, stop:1 #34495E); /* 按下变暗 */
      transform: scale(0.98); /* 轻微缩放 */
    }
